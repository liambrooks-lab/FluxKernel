# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/fluxkernel

# ── Local LLM (Ollama) ─────────────────────────────────────────────────────────
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# ── Feature 1: Async Task Queue (Celery + Redis) ───────────────────────────────
# Redis must be running. Start with: docker-compose up redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Feature 3: Cloud LLM Fallback (Hybrid Cognitive Routing) ──────────────────
# At least one key must be set to enable cloud fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Handoff thresholds — adjust for your hardware:
#   RAM: free RAM below this (GB) triggers cloud handoff
#   TOKEN: prompt token count above this triggers cloud handoff
CLOUD_HANDOFF_RAM_THRESHOLD_GB=1.0
CLOUD_HANDOFF_TOKEN_THRESHOLD=2048

# ── Feature 5: Web Fetcher ─────────────────────────────────────────────────────
# Optional comma-separated domain allowlist (empty = all https domains allowed)
# Example: WEB_FETCH_DOMAIN_ALLOWLIST=api.github.com,docs.python.org
WEB_FETCH_DOMAIN_ALLOWLIST=

# ── Security ───────────────────────────────────────────────────────────────────
# Leave empty in dev (all requests allowed). Set in production.
FLUX_API_KEY=
